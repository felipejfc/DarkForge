{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DarkForge Console",
  "version": "0.1.0",
  "identifier": "dev.darkforge.console",
  "build": {
    "frontendDist": "../frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "DarkForge Console",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": null,
      "dangerousDisableAssetCspModification": true
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/kserver"],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
